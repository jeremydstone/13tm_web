{
  "name": "13tm-web",
  "version": "1.0.0",
  "private": true,
  "description": "Static website for the band 13 Til Midnight",
  "type": "module",
  "scripts": {
    "lint:html": "html-validate index.html pics/index.html videos/index.html contact/index.html",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:js": "eslint \"js/**/*.js\"",
    "check:links": "node scripts/check-links.mjs",
    "check:photos": "node scripts/check-photos.mjs",
    "thumbs": "node scripts/gen-thumbs.mjs",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "test": "npm run lint && npm run check:links && npm run check:photos"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "html-validate": "^9.7.1",
    "stylelint": "^16.11.0",
    "stylelint-config-standard": "^36.0.1"
  }
}
